{
  "manifest_version": 3,
  "name": "TabTopic Organizer",
  "version": "0.6.0",
  "description": "Analyze and group open tabs by topic with custom categories, auto-grouping, and session management",
  "permissions": ["tabs", "tabGroups", "storage", "contextMenus"],
  "background": {
    "scripts": ["utils.js", "background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "32": "icons/icon-32.svg",
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    }
  },
  "commands": {
    "group-tabs": {
      "suggested_key": { "default": "Alt+Shift+G" },
      "description": "Group all tabs by topic"
    },
    "ungroup-tabs": {
      "suggested_key": { "default": "Alt+Shift+U" },
      "description": "Ungroup all tabs"
    },
    "undo-group": {
      "suggested_key": { "default": "Alt+Shift+Z" },
      "description": "Undo last grouping"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tabtopic-organizer@example.com",
      "strict_min_version": "128.0"
    }
  }
}
