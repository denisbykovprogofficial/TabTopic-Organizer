{
  "manifest_version": 3,
  "name": "TabTopic Organizer",
  "version": "1.0.0",
  "description": "Автоматический анализ и группировка открытых вкладок по тематике на основе заголовков и URL",

  "permissions": [
    "tabs",
    "tabGroups"
  ],

  "background": {
    "scripts": ["utils.js", "background.js"]
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "tabtopic-organizer@example.com",
      "strict_min_version": "128.0"
    }
  }
}
